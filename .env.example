# HMRC MTD sandbox credentials (Developer Hub) — copy to .env, never commit .env
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_REDIRECT_URI=http://localhost:8080/callback
# Sandbox only. A guard test asserts this is the sandbox host.
HMRC_BASE_URL=https://test-api.service.hmrc.gov.uk

# Sandbox test user (VRN + creds with an open VAT obligation period)
HMRC_TEST_VRN=

# OpenAI — extraction model (classification → single structured call, not an agent)
# Using OpenAI for v1 to spend existing credits; swappable back via this one var + config.py.
OPENAI_API_KEY=
EXTRACTION_MODEL=gpt-4o-mini
# Cheap default above (good for budget). Stronger option: gpt-4o
# Use OpenAI Structured Outputs (response_format = json_schema, strict) so the call is schema-constrained.
